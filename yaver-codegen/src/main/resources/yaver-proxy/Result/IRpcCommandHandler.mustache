namespace {{packageName}}.Result;

/// <summary>
///   Marker interface for RPC command handlers that should be automatically registered with FastEndpoints.
///   Use this interface to mark handlers that are intended for remote procedure calls.
///   This interface extends ICommandHandler to provide both marker functionality and FastEndpoints compatibility.
/// </summary>
/// <typeparam name="TCommand">The type of command to handle.</typeparam>
/// <typeparam name="TResult">The type of result returned by the command.</typeparam>
public interface IRpcCommandHandler<TCommand, TResult> : ICommandHandler<TCommand, TResult>
  where TCommand : notnull, ICommand<TResult>
  where TResult : notnull
{
  // Marker interface that extends ICommandHandler - no additional methods needed
}

/// <summary>
///   Represents an RPC command that returns a result of type <typeparamref name="TResult" />.
/// </summary>
/// <typeparam name="TResult">The type of the result returned by the command.</typeparam>
public interface IRpcCommand<out TResult> : ICommand<TResult>
  where TResult : notnull
{
}
