using FluentValidation.Results;

using Microsoft.AspNetCore.Http;

namespace {{packageName}}.Result;

/// <summary>
/// Provides extension methods for converting Result objects to HTTP responses using a fluent API.
/// Supports both synchronous Result{T} and asynchronous Task{Result{T}} patterns.
/// </summary>
public static class ResultToResponse
{
  /// <summary>
  /// Sends a Result as an HTTP response with automatic status code mapping.
  /// Success responses return the value directly, error responses return ProblemDetails.
  /// </summary>
  /// <typeparam name="T">The type of the result value</typeparam>
  /// <param name="result">The Result object to send</param>
  /// <param name="httpContext">The HttpContext to send the response to</param>
  /// <param name="successStatusCode">HTTP status code for successful responses (default: 200)</param>
  /// <param name="cancellationToken">Cancellation token for the async operation</param>
  /// <returns>A task representing the async send operation</returns>
  /// <example>
  /// <code>
  /// var result = await someService.GetDataAsync();
  /// await result.SendAsync(HttpContext, StatusCodes.Status201Created, ct);
  /// </code>
  /// </example>
  public static async Task SendAsync<T>(
    this Result<T> result,
    HttpContext httpContext,
    int successStatusCode = 200,
    CancellationToken cancellationToken = default)
  {
    if (result.Status == ResultStatus.Ok)
    {
      await httpContext.Response.SendAsync(
        result.Value,
        successStatusCode,
        cancellation: cancellationToken).ConfigureAwait(false);
    }
    else
    {
      var (response, statusCode) = GetErrorResponse(result);
      await httpContext.Response.SendAsync(
          response,
          statusCode,
          cancellation: cancellationToken)
        .ConfigureAwait(false);
    }
  }

  /// <summary>
  /// Fluent extension for sending Task{Result{T}} directly as HTTP response.
  /// Awaits the task, then sends the result with automatic status code mapping.
  /// </summary>
  /// <typeparam name="T">The type of the result value</typeparam>
  /// <param name="resultTask">The Task containing the Result to send</param>
  /// <param name="httpContext">The HttpContext to send the response to</param>
  /// <param name="successStatusCode">HTTP status code for successful responses (default: 200)</param>
  /// <param name="cancellationToken">Cancellation token for the async operation</param>
  /// <returns>A task representing the async send operation</returns>
  /// <example>
  /// <code>
  /// await command
  ///   .RemoteExecuteAsync(ct)
  ///   .SendAsync(HttpContext, StatusCodes.Status201Created, ct);
  /// </code>
  /// </example>
  public static async Task SendAsync<T>(
    this Task<Result<T>> resultTask,
    HttpContext httpContext,
    int successStatusCode = 200,
    CancellationToken cancellationToken = default)
  {
    var result = await resultTask.ConfigureAwait(false);
    await result.SendAsync(httpContext, successStatusCode, cancellationToken).ConfigureAwait(false);
  }

  /// <summary>
  /// Maps Result error statuses to appropriate HTTP responses and status codes.
  /// Returns a tuple containing the ProblemDetails response and HTTP status code.
  /// </summary>
  /// <typeparam name="T">The type of the result value</typeparam>
  /// <param name="result">The failed Result to map</param>
  /// <returns>Tuple containing IResult response and HTTP status code</returns>
  private static (Microsoft.AspNetCore.Http.IResult response, int statusCode) GetErrorResponse<T>(Result<T> result)
  {
    return result.Status switch
    {
      ResultStatus.NotFound => CreateErrorResponse(result, StatusCodes.Status404NotFound),
      ResultStatus.Unauthorized => CreateErrorResponse(result, StatusCodes.Status401Unauthorized),
      ResultStatus.Forbidden => CreateErrorResponse(result, StatusCodes.Status403Forbidden),
      ResultStatus.Invalid => CreateBadRequestResponse(result, StatusCodes.Status400BadRequest),
      ResultStatus.Error => CreateErrorResponse(result, StatusCodes.Status422UnprocessableEntity),
      ResultStatus.Conflict => CreateErrorResponse(result, StatusCodes.Status409Conflict),
      ResultStatus.CriticalError => CreateErrorResponse(result, StatusCodes.Status500InternalServerError),
      ResultStatus.Unavailable => CreateErrorResponse(result, StatusCodes.Status503ServiceUnavailable),
      ResultStatus.Ok => throw new NotImplementedException(),
      _ => CreateErrorResponse(result, StatusCodes.Status500InternalServerError)
    };
  }

  #region Private Response Creators

  /// <summary>
  /// Creates a standardized error response with the given status code.
  /// </summary>
  private static (Microsoft.AspNetCore.Http.IResult response, int statusCode) CreateErrorResponse(IResult result, int statusCode)
  {
    var problemDetails = new ProblemDetails(
      [.. result.Errors.Select(e => new ValidationFailure("", e))],
      statusCode);

    return (problemDetails, statusCode);
  }

  /// <summary>
  /// Creates a bad request response specifically for validation errors.
  /// </summary>
  private static (Microsoft.AspNetCore.Http.IResult response, int statusCode) CreateBadRequestResponse(IResult result, int statusCode)
  {
    var problemDetails = new ProblemDetails(
      [.. result.ValidationErrors.Select(e => new ValidationFailure(e.Identifier, e.ErrorMessage))],
      statusCode);

    return (problemDetails, statusCode);
  }

  #endregion
}
