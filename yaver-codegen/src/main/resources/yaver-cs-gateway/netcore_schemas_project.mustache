<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>{{targetFramework}}</TargetFramework>
    <AssemblyName>{{schemasPackageName}}</AssemblyName>
    <RootNamespace>{{schemasPackageName}}</RootNamespace>
    <OutputType>Library</OutputType>
    <Nullable>annotations</Nullable>
    <NoWarn>1591</NoWarn>
    <FluentValidationVersion>{{fluentValidationVersion}}</FluentValidationVersion>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
    <EnableTrimAnalyzer>true</EnableTrimAnalyzer>
    <EnableAotAnalyzer>true</EnableAotAnalyzer>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation" Version="$(FluentValidationVersion)" />
    <PackageReference Include="MessagePack" Version="3.1.4" />
    <PackageReference Include="MessagePack.Annotations" Version="3.1.4" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="System" />
    <Using Include="System.Runtime.Serialization" />
    <Using Include="System.Text.Json.Serialization" />
    <Using Include="FluentValidation" />
  </ItemGroup>

</Project>
